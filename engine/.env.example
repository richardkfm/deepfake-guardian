# Engine configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# API authentication — set a strong random secret; leave empty to disable (dev only)
API_KEY=

# Rate limiting per IP on moderation endpoints (e.g. "60/minute", "10/second")
RATE_LIMIT=60/minute

# i18n — comma-separated list of enabled language pack codes
ENABLED_LANGUAGES=en,de

# Moderation profile — sets all thresholds at once (individual vars below still override)
# Options: minors_strict | default | permissive
MODERATION_PROFILE=default

# Thresholds (0.0 - 1.0) — content above these scores triggers "delete"
# Leave commented out to use the profile defaults above.
THRESHOLD_VIOLENCE=0.6
THRESHOLD_SEXUAL_VIOLENCE=0.6
THRESHOLD_NSFW=0.6
THRESHOLD_DEEPFAKE=0.8
THRESHOLD_CYBERBULLYING=0.6

# ---------------------------------------------------------------------------
# Opt-in moderation categories (moderation skills)
# ---------------------------------------------------------------------------
# Core child-safety categories (violence, sexual_violence, nsfw, deepfake,
# cyberbullying) are ALWAYS on. Additional categories are defined as editable
# markdown "skills" in engine/moderation/skills/*.md and are OFF by default.
# Enable them with a comma-separated list of skill ids. Available opt-in skills:
#   advertising, scams, political_misinformation, hate_speech, self_harm
#   ENABLED_CATEGORIES=advertising,scams,political_misinformation,hate_speech,self_harm
ENABLED_CATEGORIES=
# Each opt-in category honours its own THRESHOLD_<ID> override, e.g.:
# THRESHOLD_ADVERTISING=0.85
# THRESHOLD_POLITICAL_MISINFORMATION=0.8
# THRESHOLD_HATE_SPEECH=0.6
# THRESHOLD_SCAMS=0.8
# THRESHOLD_SELF_HARM=0.8

# ---------------------------------------------------------------------------
# Deepfake detection
# ---------------------------------------------------------------------------
# Provider: openai | ollama | local | sightengine | api | stub
#
# Recommended for most users:
#   "openai"  — uses OpenAI Vision API (set OPENAI_API_KEY below)
#   "ollama"  — uses a local Ollama instance with a vision model (e.g. llava)
#
# Advanced:
#   "local"   — on-device ONNX model (high RAM/disk; see docs for requirements)
#   "sightengine" — SightEngine cloud API
#   "api"     — any HTTP endpoint returning a score
#
# Default:
#   "stub"    — returns 0.05 (safe for CI/testing; no real detection)
#
# To enable deepfake detection, set a provider and its credentials below.
DEEPFAKE_PROVIDER=stub

# --- OpenAI provider (DEEPFAKE_PROVIDER=openai) ---
# Get your key at https://platform.openai.com/api-keys
# Face images are sent to OpenAI — consider GDPR implications for minors.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Override for OpenAI-compatible APIs (e.g. Azure OpenAI, LiteLLM proxy)
OPENAI_API_BASE=https://api.openai.com/v1

# --- Ollama provider (DEEPFAKE_PROVIDER=ollama) ---
# Run Ollama locally: https://ollama.com — then pull a vision model:
#   ollama pull llava
# Privacy-friendly: all data stays on your machine.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava

# --- Local ONNX provider (DEEPFAKE_PROVIDER=local) ---
# Requires onnxruntime, mediapipe, opencv-python-headless (~500MB+ RAM)
# Path to ONNX model file (auto-downloaded if empty)
DEEPFAKE_MODEL_PATH=

# --- SightEngine cloud provider (DEEPFAKE_PROVIDER=sightengine) ---
# WARNING: face images will be sent to SightEngine's servers
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# --- Generic API provider (DEEPFAKE_PROVIDER=api) ---
# WARNING: face images will be sent to this endpoint
DEEPFAKE_API_URL=
DEEPFAKE_API_KEY=
DEEPFAKE_API_SCORE_PATH=score

# ---------------------------------------------------------------------------
# Video processing
# ---------------------------------------------------------------------------
# Seconds between sampled frames
FRAME_INTERVAL=2.0
# Maximum number of frames to analyse per video
MAX_FRAMES=10
# Maximum video duration in seconds (longer videos are rejected)
MAX_VIDEO_DURATION=300

# GDPR / persistence
# SQLite (default, zero-config) or PostgreSQL: postgresql+asyncpg://user:pw@host/db
DATABASE_URL=sqlite+aiosqlite:///./deepfake_guardian.db
# Secret salt for hashing user/group IDs — set a strong random value in production
GDPR_SALT=change-me-in-production
# Days before moderation events are automatically deleted (Article 5(1)(e))
DATA_RETENTION_DAYS=30
